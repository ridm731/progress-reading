# このファイルを .env.local にコピーして、各値を埋めてください
#   cp .env.example .env.local
# 取得方法の詳細は SETUP.md を参照

# --- 必須 ---

# Neon のデータベース接続文字列(Neon ダッシュボード → Connect → Connection string)
DATABASE_URL=

# NextAuth のセッション暗号化キー(`npx auth secret` で生成、または `openssl rand -base64 32`)
AUTH_SECRET=

# Google OAuth クライアント(Google Cloud Console で作成。SETUP.md の手順3)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# アプリのURL(ローカルは http://localhost:3000、Vercel 本番はデプロイ後のURL)
NEXTAUTH_URL=http://localhost:3000

# ログインを許可する Gmail アドレス(自分のアドレスを設定。ここに無いアカウントはログイン不可)
ALLOWED_EMAIL=

# --- 任意 ---

# AIフィードバック用の Gemini API キー(https://aistudio.google.com/apikey で取得)
# 未設定でもアプリは動きますが、AIフィードバック機能だけ使えません
GEMINI_API_KEY=

# true にすると DB を使わずモックデータで表示(開発用)
USE_MOCK=false

# 審査員向けデモモード(通常は使いません)
DEMO_MODE=false
DEMO_USER_ID=
